# Dashboard server
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3400
DASHBOARD_TIMEZONE=-5  # UTC offset in hours (e.g., -5 for EST, +1 for CET, 0 for UTC)
DASHBOARD_COLLECT_INTERVAL_MIN=20  # In-process auto-collector cadence in minutes; 0 disables it

# Remote sync (used by scripts/push-usage.sh on remote machines, optional)
DASHBOARD_URL=http://localhost:3400
